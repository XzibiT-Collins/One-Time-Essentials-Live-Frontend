# Dev image: Vite + Express dev server with hot reload (port 3000).
# The prod image (Dockerfile) builds a static bundle served by nginx; this one
# runs `npm run dev`. Source is bind-mounted by compose so edits hot-reload.
FROM node:22-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
EXPOSE 3000
CMD ["npm", "run", "dev"]
